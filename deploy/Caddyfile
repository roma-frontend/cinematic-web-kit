# Caddyfile — automatic HTTPS (Let's Encrypt) for the platform + tenant custom domains.
#
# Prereqs:
#   - Next.js app running on 127.0.0.1:3000 (e.g. `npm run start` behind a process manager).
#   - DNS: A/AAAA for your platform host and a wildcard *.example.com → this server.
#   - Ports 80 and 443 open to the internet (Let's Encrypt HTTP/TLS-ALPN challenge).
#   - Replace example.com with your NEXT_PUBLIC_APP_HOST domain.
#
# How tenant custom domains get a cert automatically:
#   Caddy's "on-demand TLS" issues a certificate the first time a visitor hits an
#   unknown domain over HTTPS — but ONLY if the `ask` endpoint approves it. We
#   point `ask` at the app's /api/tls-check, which returns 200 only for domains
#   attached to a real site. This prevents cert-request abuse.

{
	# Global options
	email you@example.com   # Let's Encrypt account (change me)

	on_demand_tls {
		ask http://127.0.0.1:3000/api/tls-check
		# rate limits are recommended in production:
		# interval 2m
		# burst 5
	}
}

# ── Platform host + its wildcard subdomains (tenant slugs: <slug>.example.com) ──
example.com, *.example.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:3000
}

# ── Tenant CUSTOM domains (any other hostname) — cert issued on demand via `ask` ──
:443 {
	tls {
		on_demand
	}
	encode zstd gzip
	reverse_proxy 127.0.0.1:3000
}

# Redirect all plain HTTP to HTTPS (Caddy does this automatically for named
# sites; this catch-all covers on-demand hosts too).
:80 {
	redir https://{host}{uri} permanent
}
